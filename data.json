<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NFPC/NFTC 자동 모니터링 대시보드</title>
    <style>
        /* 기본 스타일 */
        body {
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
            margin: 0;
            padding: 20px;
            background-color: #f8f9fa;
            color: #333;
        }
        h1, h2, h3 {
            color: #2c3e50;
        }
        .container {
            max-width: 1200px;
            margin: 0 auto;
            background-color: #fff;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        
        /* 요약 카드 스타일 */
        .summary-cards {
            display: flex;
            gap: 20px;
            margin-bottom: 30px;
        }
        .card {
            flex: 1;
            padding: 20px;
            border-radius: 8px;
            background-color: #f1f8ff;
            border: 1px solid #c8e1ff;
            text-align: center;
        }
        .card h3 {
            margin-top: 0;
            font-size: 16px;
            color: #0366d6;
        }
        .card p {
            font-size: 24px;
            font-weight: bold;
            margin: 10px 0 0 0;
        }

        /* 변경 이력 리스트 스타일 */
        .history-list {
            list-style: none;
            padding: 0;
        }
        .history-item {
            background-color: #fff;
            border: 1px solid #ddd;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 5px;
            cursor: pointer;
            transition: background-color 0.2s;
        }
        .history-item:hover {
            background-color: #f1f8ff;
            border-color: #c8e1ff;
        }
        .history-date {
            font-weight: bold;
            color: #555;
            margin-bottom: 5px;
        }
        .history-summary {
            color: #0366d6;
            font-weight: bold;
        }
        
        /* 배지 스타일 */
        .badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 12px;
            font-size: 12px;
            font-weight: bold;
            color: white;
            margin-right: 5px;
        }
        .badge.changed { background-color: #e74c3c; }
        .badge.no-change { background-color: #2ecc71; }
        .badge.nfpc { background-color: #3498db; }
        .badge.nftc { background-color: #9b59b6; }

        /* 모달 (팝업창) 스타일 */
        .modal {
            display: none; 
            position: fixed;
            z-index: 1000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            overflow: auto; /* 내용이 길면 스크롤 */
        }
        .modal-content {
            background-color: #fefefe;
            margin: 5% auto;
            padding: 30px;
            border: 1px solid #888;
            width: 70%;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            position: relative;
        }
        .close-btn {
            position: absolute;
            top: 15px;
            right: 25px;
            color: #aaa;
            font-size: 28px;
            font-weight: bold;
            cursor: pointer;
        }
        .close-btn:hover { color: #333; }
        
        /* 상세 변경 내역 테이블 */
        .changes-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }
        .changes-table th, .changes-table td {
            border: 1px solid #ddd;
            padding: 12px;
            text-align: left;
        }
        .changes-table th {
            background-color: #f8f9fa;
            color: #2c3e50;
        }
        .no-changes-msg {
            text-align: center;
            padding: 20px;
            color: #7f8c8d;
            font-style: italic;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>NFPC/NFTC 자동 모니터링 대시보드</h1>
    <p>국가법령정보센터 OPEN API 기반 · 전체 기준 일일 점검</p>
    <p id="last-update" style="color: #7f8c8d; font-size: 14px;">데이터 불러오는 중...</p>

    <div class="summary-cards">
        <div class="card">
            <h3>최근 점검일 변경 사항</h3>
            <p id="latest-changed-count">- 건</p>
        </div>
        <div class="card">
            <h3>NFPC 상태 (최근)</h3>
            <p id="nfpc-status" style="font-size: 16px; margin-top:15px;">-</p>
        </div>
        <div class="card">
            <h3>NFTC 상태 (최근)</h3>
            <p id="nftc-status" style="font-size: 16px; margin-top:15px;">-</p>
        </div>
    </div>

    <h2>변경 이력 (클릭하여 상세 보기)</h2>
    <div id="history-container">
        <p>데이터를 불러오는 중입니다...</p>
    </div>
</div>

<div id="detailModal" class="modal">
    <div class="modal-content">
        <span class="close-btn" onclick="closeModal()">&times;</span>
        <h2 id="modal-date">YYYY-MM-DD 상세 내역</h2>
        
        <div id="modal-summary-box" style="background: #f1f8ff; padding: 15px; border-radius: 5px; margin-bottom: 20px;">
            <strong id="modal-summary-text"></strong>
        </div>

        <h3>📝 상세 변경 사항</h3>
        <div id="modal-details-container">
            </div>
    </div>
</div>

<script>
    // data.json 파일을 불러오는 함수
    async function fetchData() {
        try {
            // 실제 환경에서는 fetch('./data.json') 경로를 사용하세요.
            const response = await fetch('data.json'); 
            const data = await response.json();
            
            updateDashboard(data);
            renderHistory(data.records);
        } catch (error) {
            console.error('데이터 로드 실패:', error);
            document.getElementById('history-container').innerHTML = '<p style="color:red;">데이터를 불러오는 데 실패했습니다.</p>';
        }
    }

    // 대시보드 상단 요약 정보 업데이트
    function updateDashboard(data) {
        if (!data || !data.records || data.records.length === 0) return;

        // 가장 최근 데이터
        const latest = data.records[0];
        
        document.getElementById('last-update').innerText = `마지막 실행: ${new Date(data.lastRun).toLocaleString()}`;
        
        const totalChanged = latest.stats.nfpc.changed + latest.stats.nftc.changed;
        document.getElementById('latest-changed-count').innerText = `${totalChanged} 건`;
        document.getElementById('latest-changed-count').style.color = totalChanged > 0 ? '#e74c3c' : '#2ecc71';

        document.getElementById('nfpc-status').innerText = `전체 ${latest.stats.nfpc.total} | 발견 ${latest.stats.nfpc.found} | 에러 ${latest.stats.nfpc.error} | 변경 ${latest.stats.nfpc.changed}`;
        document.getElementById('nftc-status').innerText = `전체 ${latest.stats.nftc.total} | 발견 ${latest.stats.nftc.found} | 에러 ${latest.stats.nftc.error} | 변경 ${latest.stats.nftc.changed}`;
    }

    // 변경 이력 리스트 렌더링
    function renderHistory(records) {
        const container = document.getElementById('history-container');
        container.innerHTML = ''; // 기존 내용 지우기

        const ul = document.createElement('ul');
        ul.className = 'history-list';

        records.forEach(record => {
            const li = document.createElement('li');
            li.className = 'history-item';
            
            // 변경 유무에 따른 뱃지
            const isChanged = record.result === "변경 있음";
            const badgeClass = isChanged ? 'badge changed' : 'badge no-change';
            
            li.innerHTML = `
                <div class="history-date">${record.date} <span style="font-size: 12px; color: #888;">(${new Date(record.checkedAt).toLocaleTimeString()})</span></div>
                <div>
                    <span class="${badgeClass}">${record.result}</span>
                    <span class="history-summary">${record.summary}</span>
                </div>
            `;
            
            // 리스트 클릭 이벤트 추가
            li.onclick = () => openModal(record);
            ul.appendChild(li);
        });

        container.appendChild(ul);
    }

    // 모달 열기 및 데이터 채우기
    function openModal(record) {
        document.getElementById('modal-date').innerText = `${record.date} 점검 결과`;
        document.getElementById('modal-summary-text').innerText = record.summary;

        const detailsContainer = document.getElementById('modal-details-container');
        detailsContainer.innerHTML = ''; // 초기화

        // 변경된 항목이 없는 경우
        if (!record.changes || record.changes.length === 0) {
            detailsContainer.innerHTML = '<div class="no-changes-msg">이 날짜에는 감지된 변경 사항이나 오류가 없습니다.</div>';
        } else {
            // 변경 내역이 있는 경우 테이블 생성
            let tableHTML = `
                <table class="changes-table">
                    <thead>
                        <tr>
                            <th>구분</th>
                            <th>코드명 / 법령명</th>
                            <th>상태</th>
                            <th>개정유형 / 시행일</th>
                            <th>비고 (개정이유 등)</th>
                        </tr>
                    </thead>
                    <tbody>
            `;

            record.changes.forEach(change => {
                const scopeBadge = change.scope === 'NFPC' ? '<span class="badge nfpc">NFPC</span>' : '<span class="badge nftc">NFTC</span>';
                
                // 에러 상태일 경우 스타일 다르게 처리
                const statusColor = change.status === 'ERROR' ? 'color: red; font-weight: bold;' : 'color: green;';
                
                // 개정 유형이나 사유가 빈 값일 경우 처리
                const revisionInfo = change.revisionType ? `${change.revisionType}<br><span style="font-size:12px;color:#666;">(시행: ${change.effectiveDate})</span>` : '-';
                const reasonInfo = change.reason || (change.status === 'ERROR' ? '데이터 수집 중 오류 발생' : '-');

                tableHTML += `
                    <tr>
                        <td style="text-align:center;">${scopeBadge}</td>
                        <td>
                            <strong>${change.code}</strong><br>
                            ${change.title}
                        </td>
                        <td style="${statusColor}">${change.status}</td>
                        <td>${revisionInfo}</td>
                        <td>${reasonInfo}</td>
                    </tr>
                `;
            });

            tableHTML += `</tbody></table>`;
            detailsContainer.innerHTML = tableHTML;
        }

        document.getElementById('detailModal').style.display = "block";
    }

    // 모달 닫기
    function closeModal() {
        document.getElementById('detailModal').style.display = "none";
    }

    // 모달 바깥 배경 클릭 시 닫기
    window.onclick = function(event) {
        const modal = document.getElementById('detailModal');
        if (event.target == modal) {
            modal.style.display = "none";
        }
    }

    // 스크립트 실행 (데이터 불러오기)
    fetchData();
</script>

</body>
</html>
